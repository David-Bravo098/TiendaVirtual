@model List<TiendaVirtual.Models.Categoria>

<h2>Lista de Categorías</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Estado</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>

                <td>
                    @if (!string.IsNullOrEmpty(item.Nombre))
                    {
                        <span class="text-success">Activa</span>
                    }
                    else
                    {
                        <span class="text-danger">Sin nombre</span>
                    }
                </td>

            </tr>
        }

    </tbody>
</table>